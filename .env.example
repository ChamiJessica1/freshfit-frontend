# Vite env vars must be prefixed with VITE_ to reach the client bundle.
#
# Base URL of the Fresh & Fit backend API. This is OPTIONAL — when unset the
# client auto-picks the right backend based on where the app is being served:
#   - hostname is localhost / 127.0.0.1  -> http://localhost:5000/api
#   - any other hostname (e.g. Vercel)   -> https://fresh-fit-backend.onrender.com/api
# Set this only if you want to force a specific backend (e.g. point local dev
# at the deployed backend, or vice versa).
# VITE_API_BASE=http://localhost:5000/api
